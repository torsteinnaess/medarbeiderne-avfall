{
  "expo": {
    "name": "Avfall Henting",
    "slug": "avfall-henting",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "avfallhenting",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2D7D46"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "no.avfallhenting.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2D7D46",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "no.avfallhenting.app",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Appen trenger tilgang til bildene dine for å analysere avfall.",
          "cameraPermission": "Appen trenger tilgang til kameraet for å ta bilder av avfall."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
